# TokenMonitor Environment Variables
# ===================================
# 复制此文件为 .env 并填入你的 API Keys
#   cp .env.example .env
#
# .env 文件不会提交到 Git（已在 .gitignore 中排除）

# ── DeepSeek API ──────────────────────────────────
# 获取地址: https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=

# ── OpenAI API ────────────────────────────────────
# 获取地址: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# ── Anthropic API ─────────────────────────────────
# 获取地址: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# ── Gemini API ────────────────────────────────────
# 获取地址: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# ── OpenRouter API ────────────────────────────────
# 获取地址: https://openrouter.ai/keys
OPENROUTER_API_KEY=
